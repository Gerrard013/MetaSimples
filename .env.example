SECRET_KEY=troque_por_uma_chave_forte
FLASK_ENV=production
DATABASE_URL=postgresql://usuario:senha@host:5432/database

APP_NAME=G Tech Platform
APP_BASE_URL=https://seu-app.up.railway.app
SUPPORT_WHATSAPP=5591999999999
DEFAULT_TRIAL_DAYS=7

ADMIN_EMAIL=admin@seudominio.com
ADMIN_PASSWORD=troque_essa_senha_forte

# E-mail/RPA via Resend
MAIL_ENABLED=true
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_sua_chave_resend
MAIL_FROM_NAME=G Tech
MAIL_FROM_EMAIL=onboarding@seudominio.com

# Mercado Pago — Checkout Pro cria Pix/cartão conforme sua conta Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=APP_USR_ou_TEST_seu_access_token
MERCADOPAGO_PUBLIC_KEY=APP_USR_ou_TEST_sua_public_key
MERCADOPAGO_WEBHOOK_SECRET=
MERCADOPAGO_STATEMENT_DESCRIPTOR=GTECH
MERCADOPAGO_MAX_INSTALLMENTS=3
MERCADOPAGO_FEE_PERCENT=5.31
MERCADOPAGO_FEE_FIXED=0.00

# Preços base líquidos. O app soma taxa do Mercado Pago no checkout.
PLAN_CONTROLE_MENSAL_PRICE=150.00
PLAN_CONTROLE_TRIMESTRAL_PRICE=299.70
PLAN_CONTROLE_ANUAL_PRICE=958.80
PLAN_METASIMPLES_MENSAL_PRICE=150.00
PLAN_METASIMPLES_TRIMESTRAL_PRICE=299.70
PLAN_METASIMPLES_ANUAL_PRICE=958.80

# true = exige pagamento antes; false = libera trial e depois admin/cobrança
PAYMENT_REQUIRED_BEFORE_ACCESS=false

# IA: local funciona sem token. Para Groq use AI_PROVIDER=groq e cole token.
AI_PROVIDER=local
AI_API_KEY=
AI_MODEL=llama-3.1-8b-instant
AI_API_BASE_URL=
